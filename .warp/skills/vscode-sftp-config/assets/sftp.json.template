[
  {
    "name": "{{PROJECT_NAME}}",
    "host": "{{HOST_ALIAS}}",
    "protocol": "sftp",
    "port": 22,
    "username": "{{SSH_USERNAME}}",
    "privateKeyPath": "{{SSH_KEY_PATH}}",
    "remotePath": "{{REMOTE_PATH}}",
    "uploadOnSave": false,
    "useTempFile": false,
    "openSsh": false,
    "downloadOnOpen": false,
    "ignore": [
      ".vscode",
      ".claude",
      ".git",
      ".DS_Store",
      "node_modules",
      "docs",
      ".gitignore",
      "README.md",
      "CLAUDE.md",
      "CONFIG.md",
      ".drone.yml",
      "deploy.sh",
      "package.json",
      "package-lock.json",
      "tsconfig.json",
      "nginx.conf",
      "nginx-static.conf"
    ],
    "watcher": {
      "files": "**/*",
      "autoUpload": false,
      "autoDelete": false
    },
    "syncOption": {
      "delete": false,
      "skipCreate": false,
      "ignoreExisting": false,
      "update": true
    },
    "profiles": {}
  }
]
